// taskintern-visualizer/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------
// Core User Model
// ---------------------------------------------------------
model User {
  id        String           @id @default(uuid())
  email     String           @unique
  name      String?
  progress  ModuleProgress[]
  scores    QuizScore[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

// ---------------------------------------------------------
// Open Innovation: Learning Analytics Tracking
// ---------------------------------------------------------
model ModuleProgress {
  id           String   @id @default(uuid())
  userId       String
  topicId      String   // e.g., "arrays", "linked-lists"
  isCompleted  Boolean  @default(false)
  
  // Added fields to support deeper data analysis of performance
  timeSpent    Int      @default(0) // Time spent in seconds
  completedAt  DateTime?            // Exact timestamp of completion
  lastAccessed DateTime @default(now())
  
  // Relational link to the User
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Ensures a user can only have one progress record per topic
  @@unique([userId, topicId])
}

model QuizScore {
  id             String   @id @default(uuid())
  userId         String
  topicId        String   // e.g., "arrays"
  score          Int
  totalQuestions Int
  attemptedAt    DateTime @default(now())
  
  // Relational link to the User
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}