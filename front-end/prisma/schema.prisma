// taskintern-visualizer/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------
// Core User Model
// ---------------------------------------------------------
model User {
  id        String           @id @default(uuid())
  email     String           @unique
  name      String?
  password  String?
  image     String?
  isVerified Boolean         @default(false)
  accounts  Account[]
  progress  ModuleProgress[]
  scores    QuizScore[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

// ---------------------------------------------------------
// Open Innovation: Learning Analytics Tracking
// ---------------------------------------------------------
model ModuleProgress {
  id                      String   @id @default(uuid())
  userId                  String
  topicId                 String   // e.g., "arrays", "linked-lists"
  
  // Granular tracking fields for Dashboard
  theoryCompleted         Boolean  @default(false)
  visualizationsCompleted String[] @default([]) // Stores IDs/names of completed visualizations
  isCompleted             Boolean  @default(false) // Master flag for 100% completion
  
  // Added fields to support deeper data analysis of performance
  timeSpent               Int      @default(0) // Time spent in seconds
  completedAt             DateTime?            // Exact timestamp of completion
  lastAccessed            DateTime @default(now())
  
  // Relational link to the User
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Ensures a user can only have one progress record per topic
  @@unique([userId, topicId])
}

model QuizScore {
  id             String   @id @default(uuid())
  userId         String
  topicId        String   // e.g., "arrays"
  score          Int
  totalQuestions Int
  attemptedAt    DateTime @default(now())
  
  // Relational link to the User
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------
// NextAuth Models for OAuth & Verification
// ---------------------------------------------------------
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  id         String   @id @default(cuid())
  email      String
  token      String   
  expires    DateTime

  @@unique([email, token])
}